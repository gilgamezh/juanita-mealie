# Copy to .env and fill in. The .env file is gitignored.
# Real environment variables override values set here.

# Anthropic API key — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Base URL of your Mealie instance (no trailing slash)
MEALIE_URL=https://mealie.example.com

# Long-lived Mealie API token: Mealie UI -> Profile -> API Tokens -> create
MEALIE_TOKEN=

# Optional: load YouTube cookies from a browser to avoid caption-download rate
# limits (HTTP 429). Value is a browser name yt-dlp understands, e.g. firefox,
# chrome, chromium, brave, edge. CLI --cookies-from-browser overrides this.
# YTDLP_COOKIES_FROM_BROWSER=firefox
